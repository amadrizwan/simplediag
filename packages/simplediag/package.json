{
  "name": "simplediag",
  "version": "0.1.0",
  "description": "A small TypeScript renderer for nwdiag-compatible network diagrams.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --target es2020",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:license": "node ./scripts/check-license-isolation.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
