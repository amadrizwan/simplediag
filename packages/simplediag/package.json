{
  "name": "simplediag",
  "version": "0.2.1",
  "description": "TypeScript renderer for nwdiag-compatible network diagrams. Browser-native, no Python/Java backend.",
  "keywords": [
    "nwdiag",
    "network-diagram",
    "diagram",
    "svg",
    "blockdiag",
    "topology",
    "architecture-diagram",
    "typescript"
  ],
  "homepage": "https://github.com/amadrizwan/simplediag#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amadrizwan/simplediag.git",
    "directory": "packages/simplediag"
  },
  "bugs": {
    "url": "https://github.com/amadrizwan/simplediag/issues"
  },
  "license": "MIT",
  "author": "Amad Ali",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SUPERSET.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --target es2020",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:license": "node ./scripts/check-license-isolation.mjs",
    "audit:nwdiag": "node ./scripts/audit-nwdiag-corpus.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm check:license && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
